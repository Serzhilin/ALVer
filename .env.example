# ─── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URL
ALVER_DATABASE_URL=postgresql://user:password@localhost:5432/alver

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Auth / Security ─────────────────────────────────────────────────────────
# Required in production — generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret

# W3DS identity registry (public endpoint, usually unchanged)
PUBLIC_REGISTRY_URL=https://registry.w3ds.metastate.foundation

# Public URL of this server — used for eID wallet callbacks
# Must be reachable from the internet (your domain or ngrok URL)
VITE_PUBLIC_ALVER_BASE_URL=https://your-domain.com

# ─── Frontend (build-time — passed as Docker build arg) ──────────────────────
# The eID identifier (ename) of the facilitator account
VITE_FACILITATOR_ENAME=@your-facilitator-ename

# ─── Dev only ────────────────────────────────────────────────────────────────
# Comma-separated extra hosts Vite dev server will accept (e.g. ngrok domain)
# VITE_ALLOWED_HOSTS=your-subdomain.ngrok-free.app

# Override the API port proxied by Vite (defaults to PORT above)
# VITE_API_PORT=3001
